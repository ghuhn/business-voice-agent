# ─────────────────────────────────────────────
# LiveKit — https://cloud.livekit.io (free tier)
# Create a project → copy from Settings → Keys
# ─────────────────────────────────────────────
LIVEKIT_URL=wss://YOUR_PROJECT.livekit.cloud
LIVEKIT_API_KEY=YOUR_LIVEKIT_API_KEY
LIVEKIT_API_SECRET=YOUR_LIVEKIT_API_SECRET

# ─────────────────────────────────────────────
# Google Gemini — https://aistudio.google.com/app/apikey (free)
# ─────────────────────────────────────────────
GOOGLE_API_KEY=YOUR_GOOGLE_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash

# ─────────────────────────────────────────────
# Deepgram STT — https://console.deepgram.com (free $200 credits)
# ─────────────────────────────────────────────
DEEPGRAM_API_KEY=YOUR_DEEPGRAM_API_KEY

# ─────────────────────────────────────────────
# Cartesia TTS — https://play.cartesia.ai (free tier)
# ─────────────────────────────────────────────
CARTESIA_API_KEY=YOUR_CARTESIA_API_KEY

# ─────────────────────────────────────────────
# Lead output path (relative to agent/)
# ─────────────────────────────────────────────
LEADS_DIR=../leads
